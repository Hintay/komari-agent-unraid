<?php
require_once "/usr/local/emhttp/plugins/komari-agent/include/Helpers.php";
$cfg = array_merge([
  'ENABLED'=>'no','ENDPOINT'=>'','CONN_MODE'=>'token','TOKEN'=>'','AD_KEY'=>'',
  'DISABLE_WEB_SSH'=>'no','AUTO_UPDATE'=>'yes','GPU'=>'no','NIC_FILTER'=>'','FILTER_NICS'=>'',
  'INTERVAL'=>'1.0','IGNORE_UNSAFE_CERT'=>'no',
  'EXTRA_ARGS'=>'','VERSION'=>'latest','GHPROXY'=>''
], km_cfg_load());
$ck = function($v){ return $v === 'yes' ? 'checked' : ''; };
function km_h($v){ return htmlspecialchars($v); }
$nics = array_values(array_diff(scandir('/sys/class/net'), ['.','..']));
sort($nics);
$filterNics = array_filter(explode(',', $cfg['FILTER_NICS']));
$nicState = [];
foreach ($nics as $n) { $nicState[$n] = trim(@file_get_contents("/sys/class/net/$n/operstate") ?: 'unknown'); }
?>
